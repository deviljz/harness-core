{
  "charts_selector": "svg.chart",
  "non_chart_ids": [],
  "palette": {
    "allowed_hex": ["#79c0ff", "#7ee787", "#ffa657", "#d2a8ff", "#ffd479", "#ec4899", "#888"],
    "semantic_reserved": {}
  },
  "assertions": {
    "A1-1": {
      "enabled": true,
      "forbidden_keywords": ["frameMs"],

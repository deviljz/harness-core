    "A2-2": { "enabled": true, "min_hue_diff_deg": 30.0 },
    "A3-1": { "enabled": true, "expected_align": "left" },
    "A4-1": { "enabled": true, "units": ["MB", "ms", "KB", "个", "%"] }
  }
}
